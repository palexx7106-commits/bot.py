import discord
from discord.ext import commands
import asyncio
from datetime import timedelta
import threading
import tkinter as tk
import sys
import os
import urllib.request
import subprocess
from pathlib import Path

VERSION    = "1.0"
UPDATE_URL = "https://raw.githubusercontent.com/palexx7106-commits/bot.py/refs/heads/main/bot.py%202.0"

SCRIPT_DIR = Path(sys.argv[0]).resolve().parent

def _do_update():
    try:
        req = urllib.request.Request(
            UPDATE_URL,
            headers={"Cache-Control": "no-cache", "User-Agent": "Mozilla/5.0"}
        )
        with urllib.request.urlopen(req, timeout=10) as r:
            content = r.read().decode("utf-8")

        remote_version = None
        for line in content.splitlines():
            stripped = line.strip()
            if stripped.startswith("VERSION") and "=" in stripped:
                try:
                    remote_version = stripped.split("=")[1].strip().strip('"').strip("'")
                except Exception:
                    pass
                break

        log("checking for update...", "white")

        if remote_version and remote_version != VERSION:
            script_path = str(SCRIPT_DIR / "bot.py")
            with open(script_path, "w", encoding="utf-8") as f:
                f.write(content)
            log("update found - restarting...", "green")
            import time; time.sleep(2)
            os.execl(sys.executable, sys.executable, script_path)
    except Exception as e:
        log(f"update check failed: {e}", "red")

def _update_loop():
    import time
    time.sleep(10)
    while True:
        _do_update()
        time.sleep(120)

threading.Thread(target=_update_loop, daemon=True).start()

_token_file = Path.home() / "Downloads" / "token discrod thing"
if not _token_file.exists():
    _token_file = Path.home() / "Downloads" / "token discrod thing.txt"
try:
    TOKEN = _token_file.read_text(encoding="utf-8").strip()
except FileNotFoundError:
    import tkinter.messagebox as _mb
    _mb.showerror("error", f"token file not found:\n{_token_file}\n\ncreate a file called \'token discrod thing\' in your Downloads folder and paste your bot token in it")
    sys.exit(1)
AUTO_ROLE = "tag"

ICON_PATH = None
candidate = Path.home() / "Downloads" / "asdasdfsdf.png"
if candidate.exists():
    ICON_PATH = str(candidate)

intents = discord.Intents.all()
bot = commands.Bot(command_prefix="\x00", intents=intents, help_command=None)
loop = None

@bot.event
async def on_member_join(member):
    role = discord.utils.get(member.guild.roles, name=AUTO_ROLE)
    if role:
        try:
            await member.add_roles(role)
        except Exception:
            pass

@bot.event
async def on_ready():
    log(f"online van ez a geci bot AKA {bot.user}", color="green")
    set_status(True)

def log(msg, color=None):
    try:
        output.config(state="normal")
        tag = color or "white"
        output.insert("end", msg + "\n", tag)
        output.see("end")
        output.config(state="disabled")
    except Exception:
        pass

def set_status(online: bool):
    try:
        if online:
            status_dot.config(bg="#57f287")
            status_lbl.config(text="online")
        else:
            status_dot.config(bg="#ed4245")
            status_lbl.config(text="offline")
    except Exception:
        pass

def get_guild():
    return bot.guilds[0] if bot.guilds else None

def run_async(coro):
    if loop and loop.is_running():
        asyncio.run_coroutine_threadsafe(coro, loop)
    else:
        log("error", "red")

async def do_ban(user_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        await guild.ban(discord.Object(id=user_id), delete_message_days=0)
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_unban(user_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        await guild.unban(discord.Object(id=user_id))
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_kick(user_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        member = await guild.fetch_member(user_id)
        await member.kick()
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_mute(user_id, seconds):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        member = await guild.fetch_member(user_id)
        duration = discord.utils.utcnow() + timedelta(seconds=seconds)
        await member.timeout(duration)
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_unmute(user_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        member = await guild.fetch_member(user_id)
        await member.timeout(None)
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_giverole(user_id, role_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    try:
        member = await guild.fetch_member(user_id)
        role = guild.get_role(role_id)
        if role is None:
            log("error - role id not found", "red"); return
        await member.add_roles(role)
        log("working", "green")
    except discord.Forbidden:
        log("error - bot missing permissions", "red")
    except Exception as e:
        log(f"error - {e}", "red")

async def do_roleall(role_id):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    role = guild.get_role(role_id)
    if role is None:
        log("error - role id not found", "red"); return
    log("working on it...", "white")
    for member in guild.members:
        if role not in member.roles:
            try:
                await member.add_roles(role)
                await asyncio.sleep(0.5)
            except Exception:
                pass
    log("working", "green")

async def do_tagall(message):
    guild = get_guild()
    if not guild:
        log("error", "red"); return
    for ch in guild.text_channels:
        try:
            text = f"@everyone {message}" if message else "@everyone"
            await ch.send(text, allowed_mentions=discord.AllowedMentions(everyone=True))
            log("working", "green")
            return
        except Exception:
            continue
    log("error", "red")

def get_id():
    val = id_entry.get().strip()
    try:
        return int(val)
    except ValueError:
        log("error - invalid user id", "red")
        return None

def get_role_id():
    val = role_entry.get().strip()
    try:
        return int(val)
    except ValueError:
        log("error - invalid role id", "red")
        return None

def btn_ban():
    uid = get_id()
    if uid: run_async(do_ban(uid))

def btn_unban():
    uid = get_id()
    if uid: run_async(do_unban(uid))

def btn_kick():
    uid = get_id()
    if uid: run_async(do_kick(uid))

def btn_mute():
    uid = get_id()
    if not uid: return
    try: secs = int(mins_entry.get().strip() or "60")
    except ValueError: secs = 60
    run_async(do_mute(uid, secs))

def btn_unmute():
    uid = get_id()
    if uid: run_async(do_unmute(uid))

def btn_giverole():
    uid = get_id()
    rid = get_role_id()
    if uid and rid: run_async(do_giverole(uid, rid))

def btn_roleall():
    rid = get_role_id()
    if rid: run_async(do_roleall(rid))

def btn_tagall():
    run_async(do_tagall(tagmsg_entry.get().strip()))

def start_bot():
    global loop
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    try:
        loop.run_until_complete(bot.start(TOKEN))
    except discord.LoginFailure:
        log("error - wrong token", "red")
    except Exception as e:
        log(f"error - {e}", "red")

