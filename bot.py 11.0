F_LABEL  = ("Segoe UI", 9)
F_BOLD   = ("Segoe UI", 9, "bold")
F_TITLE  = ("Segoe UI", 15, "bold")
F_SUB    = ("Segoe UI", 8)
F_CAPS   = ("Segoe UI", 7, "bold")
F_MONO   = ("Consolas", 9)

def card(parent, pady=(0,8)):
    f = tk.Frame(parent, bg=BG2, highlightthickness=1, highlightbackground=BORDER)
    f.pack(fill="x", padx=16, pady=pady)
    return f

def section(parent, title, pady=(0,8)):
    c = card(parent, pady)
    tk.Label(c, text=title.upper(), bg=BG2, fg=FG2, font=F_CAPS).pack(anchor="w", padx=14, pady=(10,6))
    sep = tk.Frame(c, bg=BORDER, height=1)
    sep.pack(fill="x", padx=14)
    inner = tk.Frame(c, bg=BG2)
    inner.pack(fill="x", padx=14, pady=(10,14))
    return inner

def lbl(parent, text):
    return tk.Label(parent, text=text, bg=BG2, fg=FG2, font=F_SUB)

def inp(parent, width=20):
    f = tk.Frame(parent, bg=BORDER, padx=1, pady=1)
    e = tk.Entry(f, bg=ENTRY_BG, fg=FG, insertbackground=FG,
                 relief="flat", font=("Segoe UI", 10), width=width,
                 bd=4)
    e.pack()
    e.bind("<FocusIn>",  lambda ev: f.config(bg=ACCENT))
    e.bind("<FocusOut>", lambda ev: f.config(bg=BORDER))
    return f, e

def raw_inp(parent, width=20):
    frame, entry = inp(parent, width)
    return frame, entry

def btn(parent, text, cmd, color=ACCENT, hover=ACCENT2, width=None):
    kw = {}
    if width: kw["width"] = width
    b = tk.Button(parent, text=text, command=cmd,
                  bg=color, fg=FG, relief="flat", cursor="hand2",
                  font=F_BOLD, activebackground=hover,
                  activeforeground=FG, padx=14, pady=8, bd=0, **kw)
    b.bind("<Enter>", lambda e: b.config(bg=hover))
    b.bind("<Leave>", lambda e: b.config(bg=color))
    return b

def btn_red(parent, text, cmd, **kw):
    return btn(parent, text, cmd, RED, RED2, **kw)

def btn_yellow(parent, text, cmd, **kw):
    return btn(parent, text, cmd, YELLOW, YELLOW2, **kw)

def btn_green(parent, text, cmd, **kw):
    return btn(parent, text, cmd, GREEN, GREEN2, **kw)

